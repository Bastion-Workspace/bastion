FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY backend/requirements-webdav.txt .
RUN pip install --no-cache-dir -r requirements-webdav.txt

COPY backend/webdav/ /app/webdav/
COPY backend/webdav_server.py /app/

RUN mkdir -p /app/uploads /app/logs

EXPOSE 8001
CMD ["python", "webdav_server.py"]
