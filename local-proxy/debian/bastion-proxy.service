[Unit]
Description=Bastion Local Proxy Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bastion-proxy
Group=bastion-proxy
ExecStart=/usr/bin/bastion-proxy --headless --config /etc/bastion-proxy/config.yml
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
