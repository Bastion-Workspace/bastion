# Copy to minimal-external.env and edit. Use with:
#   docker compose -f docker-compose.minimal-external.yml --env-file minimal-external.env up --build
#
# Postgres app user password is fixed by backend/postgres_init init to bastion_secure_password (see DATABASE_URL in compose).
# Data workspace DB password must match postgres-data (DATA_WORKSPACE_PASSWORD).

COMPOSE_PROJECT_NAME=bastion-minimal

# --- External Qdrant (required for vector-service unless VECTOR_EMBEDDING_ENABLED=false) ---
# From other containers use host.docker.internal (Linux: ensure extra_hosts in compose; Docker Desktop works out of the box).
QDRANT_URL=http://host.docker.internal:6333

# --- External Neo4j (optional) ---
NEO4J_ENABLED=false
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- LLM (at least one provider key recommended) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- SearXNG ---
SEARXNG_SECRET=changeme-searxng-secret

# --- Auth / inter-service ---
INTERNAL_SERVICE_KEY=dev-internal-key
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt
ADMIN_PASSWORD=changeme

# --- Embedding / vector gRPC ---
VECTOR_EMBEDDING_ENABLED=true
VECTOR_EMBEDDING_REQUIRED=false
VECTOR_SERVICE_URL=vector-service:50053
EMBEDDING_DIMENSIONS=3072
HYBRID_SEARCH_ENABLED=false

# --- Image vision (no container in this stack) ---
IMAGE_VISION_ENABLED=false

# --- Data workspace DB (must match postgres-data service password) ---
DATA_WORKSPACE_PASSWORD=data_workspace_secure_password

# --- Logging (optional; same as root docker-compose LOG_LEVEL) ---
# LOG_LEVEL=INFO
# --- Celery ---
# CELERY_FLOWER_HOST_PORT=5555
