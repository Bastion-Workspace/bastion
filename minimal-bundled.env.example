# Copy to minimal-bundled.env. Merges Qdrant + Neo4j with the minimal stack:
#   docker compose -f docker-compose.minimal-external.yml -f docker-compose.minimal-bundled-addons.yml --env-file minimal-bundled.env up --build
#
# QDRANT_URL / NEO4J_URI for in-cluster services are overridden by docker-compose.minimal-bundled-addons.yml.

COMPOSE_PROJECT_NAME=bastion-minimal

# Must match NEO4J_AUTH on the neo4j service (user neo4j).
NEO4J_PASSWORD=changeme-neo4j-password

NEO4J_ENABLED=true
NEO4J_USER=neo4j

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

SEARXNG_SECRET=changeme-searxng-secret

INTERNAL_SERVICE_KEY=dev-internal-key
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt
ADMIN_PASSWORD=changeme

VECTOR_EMBEDDING_ENABLED=true
VECTOR_EMBEDDING_REQUIRED=false
VECTOR_SERVICE_URL=vector-service:50053
EMBEDDING_DIMENSIONS=3072
HYBRID_SEARCH_ENABLED=false

IMAGE_VISION_ENABLED=false

DATA_WORKSPACE_PASSWORD=data_workspace_secure_password

# CELERY_WORKER_LOG_LEVEL=INFO
# CELERY_BEAT_LOG_LEVEL=INFO
# CELERY_FLOWER_HOST_PORT=5555
