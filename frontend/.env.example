# Vite client env (must be prefixed with VITE_)
# For `npm run dev` / `docker compose --profile dev up frontend-dev`

VITE_API_URL=
VITE_APP_NAME=Bastion
VITE_VERSION=0.55.0
VITE_MAP_TILE_URL=
VITE_PMTILES_URL=/pmtiles/world.pmtiles
VITE_MAP_DARK_STYLE=

# Optional: dev server only — comma-separated Host allowlist for Vite (omit = allow all; use behind reverse proxy).
# VITE_DEV_ALLOWED_HOSTS=bastion.pilbeams.net,localhost
