# =============================================================================
# Bastion — environment template (.env)
#
# Part A: Every ${VAR} / ${VAR:-default} from root docker-compose.yml (copy to .env).
# Part B: Application-only vars (read by backend/config; not wired in compose today).
#
# Major sections are marked with banners; each lists which services consume the vars.
# =============================================================================

# =============================================================================
# COMPOSE — project name, UI profiles (not passed into containers as env)
# Used by: docker compose (image tags, container_name prefixes, profile gates).
# =============================================================================
# Profiles: prod = nginx static UI on :3051; dev = Vite HMR on :3051 — do not enable both.
COMPOSE_PROFILES=prod
COMPOSE_PROJECT_NAME=bastion

# =============================================================================
# COMPOSE — host paths for volume mounts (not generic container env)
# Used by: frontend, frontend-dev (PMTILES); valhalla (tile build / data dir).
# =============================================================================
PMTILES_DATA_PATH=./pmtiles-data
VALHALLA_DATA_PATH=./valhalla-data

# =============================================================================
# DATABASE — main cluster (postgres + pgbouncer) & app DATABASE_URL
# Used by: postgres (POSTGRES_PASSWORD); pgbouncer URL; backend, tools-service,
#           celery_worker, celery_reindex, celery_beat, webdav, document-service (host + password).
# =============================================================================
# If unset, compose defaults POSTGRES_* to bastion_secure_password — must match DB / init SQL.
POSTGRES_PASSWORD=changeme
POSTGRES_APP_PASSWORD=changeme
# DATABASE_URL hostname: pgbouncer (pooling) or postgres (direct).
BASTION_DATABASE_HOST=pgbouncer

# =============================================================================
# DATABASE — LangGraph checkpointer (orchestrator → Postgres, not via pgbouncer in compose)
# Used by: llm-orchestrator (POSTGRES_* + LANGGRAPH_POSTGRES_* for checkpoint tables).
# =============================================================================
LANGGRAPH_POSTGRES_HOST=postgres
LANGGRAPH_POSTGRES_PORT=5432
LANGGRAPH_POSTGRES_USER=langgraph_checkpoint_user
LANGGRAPH_POSTGRES_PASSWORD=langgraph_checkpoint_secure_password

# =============================================================================
# DATABASE — data workspace (separate Postgres: postgres-data + data-service)
# Used by: postgres-data init; data-service client.
# =============================================================================
# Compose default if unset: data_workspace_secure_password
DATA_WORKSPACE_PASSWORD=changeme

# =============================================================================
# RUNTIME — Linux UID/GID for rootless services (build args + `user:`)
# Used by: backend, tools-service, celery*, webdav, frontend-dev build, llm-orchestrator build,
#           vector-service, postgres-data build, data-service, image-vision, connections-service,
#           voice-service, document-service, crawl4ai-service, bbs-server (see docker-compose).
# =============================================================================
# Prefer BASTION_RUNTIME_UID/GID = `id -u` / `id -g` when bind-mounting host dirs.
# BASTION_RUNTIME_UID=
# BASTION_RUNTIME_GID=
BASTION_RUNTIME_PUID=10001
BASTION_RUNTIME_PGID=10001

# =============================================================================
# SECURITY — sessions, CSRF, service auth, bootstrap admin
# Used by: backend, celery*, webdav (JWT); backend + tools + celery* (SECRET_KEY);
#           backend, tools-service, connections-service, bbs-server (INTERNAL_SERVICE_KEY);
#           backend (ADMIN_*).
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-change-in-production
SECRET_KEY=your-secret-key-change-in-production
# One value for all services. Compose defaults: most use dev-internal-key; bbs-server uses
# changeme-internal-key if unset — set here to avoid mismatch.
INTERNAL_SERVICE_KEY=dev-internal-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@localhost

# =============================================================================
# LLM — API keys (passed through compose; empty if unset)
# Used by: backend, tools-service, celery_worker, celery_reindex, celery_beat, llm-orchestrator,
#           document-service, vector-service (OPENAI/OPENROUTER), voice-service (OPENAI);
#           crawl4ai-service (OPENROUTER only); OPENWEATHERMAP mainly backend/tools paths.
# =============================================================================
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENWEATHERMAP_API_KEY=

# =============================================================================
# LLM — default / fast / classification (orchestrator + crawl4ai)
# Used by: llm-orchestrator (DEFAULT_MODEL, FAST_MODEL, CLASSIFICATION_MODEL←FAST_MODEL in YAML);
#           crawl4ai-service (DEFAULT_MODEL ← FAST_MODEL in compose).
# =============================================================================
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
FAST_MODEL=anthropic/claude-3-haiku

# =============================================================================
# BACKEND API — process and debug
# Used by: backend (UVICORN_WORKERS, DEBUG=false default in compose).
# Note: celery_worker + celery_beat default DEBUG=true in compose; celery_reindex false.
# =============================================================================
UVICORN_WORKERS=1
DEBUG=false

# =============================================================================
# BACKEND — uploads & ranking thresholds
# Used by: backend, celery_worker, celery_reindex (UPLOAD_MAX_SIZE, QUALITY_THRESHOLD).
# =============================================================================
UPLOAD_MAX_SIZE=1500MB
QUALITY_THRESHOLD=0.7

# =============================================================================
# BACKEND — outbound email (SMTP)
# Used by: backend only.
# =============================================================================
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@bastion.local
SMTP_FROM_NAME=Bastion AI Workspace

# =============================================================================
# BACKEND — public URL & federation
# Used by: backend, celery_worker, celery_reindex_worker, celery_beat (docker-compose*.yml pass the same vars).
# =============================================================================
SITE_URL=http://localhost:3051
FEDERATION_ENABLED=false
FEDERATION_DISPLAY_NAME=

# =============================================================================
# BACKEND — maps & routing (Valhalla / OSRM clients)
# Used by: backend only.
# =============================================================================
OSRM_BASE_URL=http://osrm:5000
VALHALLA_BASE_URL=http://valhalla:8002
ROUTING_PROVIDER=valhalla

# =============================================================================
# INTEGRATIONS — Qdrant & Neo4j endpoints (shared clients)
# Used by: backend, tools-service, celery*, document-service, vector-service (QDRANT_URL);
#           same set for NEO4J_* where listed in compose.
# =============================================================================
QDRANT_URL=http://192.168.80.128:6333
NEO4J_URI=bolt://192.168.80.132:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Neo4jBoltz!

# =============================================================================
# INTEGRATIONS — vector search flags & embedding vector size (shared)
# Used by: backend, tools-service, celery*, document-service, vector-service.
# =============================================================================
HYBRID_SEARCH_ENABLED=false
EMBEDDING_DIMENSIONS=3072
VECTOR_EMBEDDING_ENABLED=true
VECTOR_EMBEDDING_REQUIRED=false

# =============================================================================
# SERVICE: vector-service — embedding backends & models
# Used by: vector-service only.
# =============================================================================
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_EMBEDDING_MODEL=
VLLM_API_KEY=

# =============================================================================
# BACKEND — image vision gRPC client toggles
# Used by: backend only (IMAGE_VISION_*).
# =============================================================================
IMAGE_VISION_ENABLED=true
IMAGE_VISION_REQUIRED=false
IMAGE_VISION_DEVICE=auto

# =============================================================================
# BACKEND / DOCUMENT-SERVICE — Redis pubsub channel names
# Used by: backend, document-service.
# =============================================================================
DOCUMENT_STATUS_REDIS_CHANNEL=bastion:document_status
FOLDER_EVENTS_REDIS_CHANNEL=bastion:folder_events

# =============================================================================
# OAUTH — Microsoft Graph (external connections / email paths)
# Used by: backend, celery_worker (MICROSOFT_*).
# =============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# =============================================================================
# OAUTH — GitHub (external connections / Agent Factory)
# Used by: backend only.
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# =============================================================================
# OBSERVABILITY — log level
# Used by: backend, tools-service, celery*, webdav, llm-orchestrator, vector-service, postgres-data,
#           data-service, image-vision, connections-service, voice-service, document-service,
#           crawl4ai-service, bbs-server (see compose per service).
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# INTEGRATIONS — optional API keys
# Used by: backend (HEDRA_API_KEY); voice-service (HEDRA_API_KEY).
# =============================================================================
HEDRA_API_KEY=

# =============================================================================
# SERVICE: searxng — instance secret
# Used by: searxng container only.
# =============================================================================
SEARXNG_SECRET=your-searxng-secret-key-change-me

# =============================================================================
# SERVICE: frontend (prod build args + prod runtime) / frontend-dev (runtime + dev bind)
# Used by: frontend Dockerfile build args; frontend + frontend-dev container env.
# =============================================================================
VITE_API_URL=
VITE_APP_NAME=Bastion
VITE_VERSION=0.70.5
VITE_MAP_TILE_URL=
VITE_PMTILES_URL=/pmtiles/world.pmtiles
VITE_MAP_DARK_STYLE=

# =============================================================================
# SERVICE: document-service — concurrency & GLiNER
# Used by: document-service only (maps to PARALLEL_WORKERS / DS_* in container).
# =============================================================================
DOCUMENT_SERVICE_PARALLEL_WORKERS=8
DOCUMENT_SERVICE_MAX_INFLIGHT_POST_UPLOAD_TASKS=24
DOCUMENT_SERVICE_MAX_TEXT_LENGTH=1000000
GLINER_MODEL=fastino/gliner2-base-v1

# =============================================================================
# SERVICE: voice-service — STT/TTS (compose sets VOICE_STT_PROVIDER=whisper literally)
# Used by: voice-service only for vars below; OPENAI_API_KEY shared from LLM section.
# =============================================================================
VOICE_TTS_PROVIDER=elevenlabs
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
ELEVENLABS_API_KEY=
PIPER_VOICE=en_US-arctic-medium
PIPER_BOOTSTRAP=1

# =============================================================================
# SERVICE: bbs-server — transports, theme, published host ports
# Used by: bbs-server only (compose maps host ports from BBS_*_PORT vars).
# =============================================================================
BBS_ENABLE_TELNET=0
BBS_ENABLE_SSH=1
BBS_TELNET_PORT=2323
BBS_SSH_PUBLISH_PORT=2222
BBS_SSH_HOST_KEY=/keys/ssh_host_ed25519_key
BBS_NAME=Bastion BBS
BBS_MAX_CONNECTIONS=20
BBS_IDLE_TIMEOUT=600
BBS_SCREEN_BLANK_AFTER_SECONDS=180
BBS_THEME=green

# #############################################################################
# PART B — Application-only (not ${...} in root docker-compose.yml today)
# Wire via compose overrides, ConfigMaps/Secrets in Kubernetes, or runtime injection.
# #############################################################################

# -----------------------------------------------------------------------------
# Backend / shared app behavior (config.py and friends)
# -----------------------------------------------------------------------------
VOICE_STT_PROVIDER=whisper
GREADER_API_ENABLED=true
NEO4J_ENABLED=true
NEO4J_REQUIRED=false
NEO4J_RECONNECT_INTERVAL_SECONDS=60
VECTOR_RECONNECT_INTERVAL_SECONDS=60
VECTOR_EMBED_BACKLOG_MAX_ATTEMPTS=10
VECTOR_EMBED_BACKLOG_PURGE_DAYS=14
QDRANT_API_KEY=
CORS_ORIGINS=http://localhost:3000,http://localhost:3050
PROCESSING_TIMEOUT=300
EMBEDDING_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Optional — Mumble (only if you add a compose / k8s service for it)
# -----------------------------------------------------------------------------
# MUMBLE_SUPERUSER_PASSWORD=changeme-mumble-admin
# MUMBLE_SERVER_PASSWORD=changeme-mumble-access
# MUMBLE_BOT_USERNAME=BastionBot
# MUMBLE_TTS_ENABLED=true

# -----------------------------------------------------------------------------
# Optional — document-service extra tuning (not in default compose env)
# -----------------------------------------------------------------------------
# DS_MAX_CONCURRENT_DOCUMENTS=12
# DS_THREAD_POOL_SIZE=12

# -----------------------------------------------------------------------------
# Optional — llm-orchestrator / Celery (fixed literals in compose today)
# -----------------------------------------------------------------------------
# DISABLE_EDITOR_ENGINE_ROUTING=false
# PIPELINE_LLM_INVOKE_TIMEOUT_SEC=900
# PLAYBOOK_GRAPH_INVOKE_TIMEOUT_SEC=900
# CELERY_ORCHESTRATOR_STREAM_TIMEOUT_SEC=1080

# -----------------------------------------------------------------------------
# Optional — federation tuning (backend/config.py defaults)
# -----------------------------------------------------------------------------
# FEDERATION_POLL_INTERVAL_SECONDS=5
# FEDERATION_CONNECTIVITY_PROBE_TIMEOUT=5
# FEDERATION_HTTP_TIMEOUT=15
