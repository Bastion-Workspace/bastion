# -----------------------------------------------------------------------------
# Required for docker-compose: POSTGRES_PASSWORD, POSTGRES_APP_PASSWORD,
# JWT_SECRET_KEY. Set POSTGRES_APP_PASSWORD to match backend/sql/01_init.sql
# (bastion_user password) or change the init script.
#
# Compose profiles: `frontend` (nginx) is profile `prod`; `frontend-dev` (Vite) is `dev`.
# - Typical production: COMPOSE_PROFILES=prod so `docker compose up` includes the prod UI on :3051.
# - Vite dev UI: `docker compose --profile dev up` — comment out or empty COMPOSE_PROFILES first,
#   or `prod` and `dev` both activate and both UIs fight for port 3051.
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=prod

# PostgreSQL (Docker Compose)
POSTGRES_PASSWORD=changeme
POSTGRES_APP_PASSWORD=changeme

# Auth (backend, frontend, connections-service, webdav OrgMode sync)
JWT_SECRET_KEY=your-jwt-secret-change-in-production

# Shared runtime uid:gid for Compose `user:` on rootless app services that write host dirs or named volumes.
# Covers e.g. backend (./data_imports, ./web_sources, ./exports, ./processed, logs, MCP caches), celery workers/beat/flower (binds + logs),
# webdav and document-service (./uploads, ./processed, ./logs), data-service (./data_imports), voice-service (models volume), vector-service (embedding cache).
# Default 10001 matches Dockerfiles. If you change this, chown bind-mounted paths (and recreate named volumes if needed) so the process can write.
# Rebuild app images after changing UID/GID (`docker compose build` for affected services, or `--build` on up) so image ownership matches Compose `user:`.
# Named volume `vector-embedding-cache` (embedding SQLite cache, not Qdrant data) keeps file ownership from the first writer; if you see "readonly database" in vector-service logs after a UID change, remove that volume once (`docker volume rm <project>_vector-embedding-cache`) or the service will fall back to `/tmp` for the cache after rebuild.
# Prefer these names (match `id -u` / `id -g` on the host for ./uploads ownership):
# BASTION_RUNTIME_UID=1000
# BASTION_RUNTIME_GID=1000
# Legacy aliases (still honored by docker-compose.yml if UID/GID unset): BASTION_RUNTIME_PUID, BASTION_RUNTIME_PGID
# Google Reader compatible RSS API at /api/greader/ (mobile clients); set false to disable
GREADER_API_ENABLED=true
INTERNAL_SERVICE_KEY=changeme-internal-key

# BBS (bbs-server container): at least one transport must be enabled.
# Defaults in docker-compose for bbs-server: telnet off, SSH on (password = Bastion login).
# BBS_ENABLE_TELNET=0
# BBS_ENABLE_SSH=1
# BBS_TELNET_PORT=2323
# BBS_SSH_PUBLISH_PORT=2222
# BBS_SSH_HOST_KEY=/keys/ssh_host_ed25519_key
# Host key file is created on first start under the named volume when SSH is enabled and the path is missing.
# BBS_SCREEN_BLANK_AFTER_SECONDS=180
# 0 = disabled. After N seconds with no input, fill screen black (Esc only resumes). Never applies in [W] wallpaper.

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenRouter Configuration
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here
DEFAULT_MODEL=anthropic/claude-3-sonnet

# Voice Service (STT/TTS) - required to activate voice-service
# Set VOICE_TTS_PROVIDER=elevenlabs (default), openai, or piper (local, no key).
# For elevenlabs (default): set ELEVENLABS_API_KEY. For openai: OPENAI_API_KEY used.
VOICE_TTS_PROVIDER=elevenlabs
VOICE_STT_PROVIDER=whisper
ELEVENLABS_API_KEY=
# Optional: WHISPER_MODEL_SIZE=small, WHISPER_DEVICE=auto, PIPER_VOICE=en_US-arctic-medium, PIPER_BOOTSTRAP=1

# Mumble Voice Server (PTT voice input to AI agent)
# MUMBLE_SUPERUSER_PASSWORD=changeme-mumble-admin
# MUMBLE_SERVER_PASSWORD=changeme-mumble-access
# MUMBLE_BOT_USERNAME=BastionBot
# MUMBLE_TTS_ENABLED=true

# Database Configuration (use defaults for development)
NEO4J_USER=neo4j
NEO4J_PASSWORD=plato_password
# Neo4j is optional by default: app starts without it; set NEO4J_REQUIRED=true to fail startup if unreachable.
NEO4J_ENABLED=true
NEO4J_REQUIRED=false
NEO4J_RECONNECT_INTERVAL_SECONDS=60

# Vector / embedding stack: optional at startup; backlog replays when healthy. Set VECTOR_EMBEDDING_REQUIRED=true to fail startup if unreachable.
# You may omit the vector-service container from Compose when VECTOR_EMBEDDING_ENABLED=false; if the container is absent but embeddings stay enabled, the client connects lazily (unless VECTOR_EMBEDDING_REQUIRED=true).
VECTOR_EMBEDDING_ENABLED=true
VECTOR_EMBEDDING_REQUIRED=false
VECTOR_RECONNECT_INTERVAL_SECONDS=60
VECTOR_EMBED_BACKLOG_MAX_ATTEMPTS=10
VECTOR_EMBED_BACKLOG_PURGE_DAYS=14

# Document service (Compose maps PARALLEL_WORKERS and DS_MAX_INFLIGHT_POST_UPLOAD_TASKS; optional overrides below)
# DOCUMENT_SERVICE_PARALLEL_WORKERS=8
# gRPC aio thread pool; scale with CPU. Raising without raising DB pool / ulimits can cause connection or EMFILE pressure.
# DOCUMENT_SERVICE_MAX_INFLIGHT_POST_UPLOAD_TASKS=24
# Max concurrent post-upload background processing tasks per document-service process (upload RPC waits when saturated).
# Optional: add to document-service environment in a compose override file (not passed by default to avoid empty env strings):
# DS_MAX_CONCURRENT_DOCUMENTS=12
# DS_THREAD_POOL_SIZE=12

# Backend HTTP (docker-entrypoint uvicorn)
# UVICORN_WORKERS=1
# Default 1. Values above 1 spawn multiple processes (separate memory and DB pool usage per worker); use only if needed.

# Image vision (YOLO/CLIP/face) gRPC service: optional. Backend no longer depends_on the container in Compose.
# Set IMAGE_VISION_ENABLED=false to skip all gRPC connection attempts (useful when the service is not deployed).
# Set IMAGE_VISION_REQUIRED=true to fail API startup if image-vision is not healthy (Celery workers do not run this check).
IMAGE_VISION_ENABLED=true
IMAGE_VISION_REQUIRED=false

QDRANT_API_KEY=
DATA_WORKSPACE_PASSWORD=changeme

# SearXNG (optional)
SEARXNG_SECRET=changeme-searxng-secret

# Microsoft OAuth (optional - external connections / email)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=

# Application Configuration
UPLOAD_MAX_SIZE=100MB
PROCESSING_TIMEOUT=300
QUALITY_THRESHOLD=0.7
EMBEDDING_BATCH_SIZE=100

# Map (PMTiles basemap; optional legacy tileserver)
# PMTILES_DATA_PATH=./pmtiles-data
# VITE_PMTILES_URL=/pmtiles/world.pmtiles
# Legacy: VITE_MAP_TILE_URL=http://localhost:8080

# Routing (Valhalla default; set ROUTING_PROVIDER=osrm and OSRM_BASE_URL for legacy OSRM)
# VALHALLA_DATA_PATH=./valhalla-data
# VALHALLA_BASE_URL=http://valhalla:8002
# ROUTING_PROVIDER=valhalla

# Development Settings
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3050

# Public URL of this deployment (federated addresses use this host; links in emails, etc.)
SITE_URL=http://localhost:3051

# Bastion-to-Bastion federation (pairing, federated rooms, cross-instance messages)
# Requires SITE_URL and SECRET_KEY; admin UI: Settings → Federation.
FEDERATION_ENABLED=false
# Optional label shown to remote peers (defaults to SITE_URL hostname if empty)
FEDERATION_DISPLAY_NAME=
# Optional tuning (defaults match backend/config.py)
# FEDERATION_POLL_INTERVAL_SECONDS=5
# FEDERATION_CONNECTIVITY_PROBE_TIMEOUT=5
# FEDERATION_HTTP_TIMEOUT=15

# LLM Orchestrator: set to true to disable Editor Engine routing so editor-doc requests
# go to chat or default Agent Factory profile (for testing Agent Factory on fiction/outline etc.).
# DISABLE_EDITOR_ENGINE_ROUTING=false

# Optional wall-clock caps for orchestrator awaits (set on llm-orchestrator service env).
# Omit, empty, or 0 = disabled (default; same as today). When set, use values above your slowest playbook.
# PIPELINE_LLM_INVOKE_TIMEOUT_SEC=900
# PLAYBOOK_GRAPH_INVOKE_TIMEOUT_SEC=900

# Celery: max seconds to consume a full orchestrator StreamChat (backend/celery_worker env).
# Default 1080 is below worker task_time_limit (1200) so tasks return a failure dict instead of SIGKILL.
# CELERY_ORCHESTRATOR_STREAM_TIMEOUT_SEC=1080

# Security (change in production)
SECRET_KEY=your-secret-key-change-in-production
