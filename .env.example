# -----------------------------------------------------------------------------
# Required for docker-compose: POSTGRES_PASSWORD, POSTGRES_APP_PASSWORD,
# JWT_SECRET_KEY. Set POSTGRES_APP_PASSWORD to match backend/sql/01_init.sql
# (bastion_user password) or change the init script.
#
# Compose profiles: `frontend` (nginx) is profile `prod`; `frontend-dev` (Vite) is `dev`.
# - Typical production: COMPOSE_PROFILES=prod so `docker compose up` includes the prod UI on :3051.
# - Vite dev UI: `docker compose --profile dev up` — comment out or empty COMPOSE_PROFILES first,
#   or `prod` and `dev` both activate and both UIs fight for port 3051.
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=prod

# PostgreSQL (Docker Compose)
POSTGRES_PASSWORD=changeme
POSTGRES_APP_PASSWORD=changeme

# Auth (backend, frontend, connections-service)
JWT_SECRET_KEY=your-jwt-secret-change-in-production
# Google Reader compatible RSS API at /api/greader/ (mobile clients); set false to disable
GREADER_API_ENABLED=true
INTERNAL_SERVICE_KEY=changeme-internal-key

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenRouter Configuration
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here
DEFAULT_MODEL=anthropic/claude-3-sonnet

# Voice Service (STT/TTS) - required to activate voice-service
# Set VOICE_TTS_PROVIDER=elevenlabs (default), openai, or piper (local, no key).
# For elevenlabs (default): set ELEVENLABS_API_KEY. For openai: OPENAI_API_KEY used.
VOICE_TTS_PROVIDER=elevenlabs
VOICE_STT_PROVIDER=whisper
ELEVENLABS_API_KEY=
# Optional: WHISPER_MODEL_SIZE=small, WHISPER_DEVICE=auto, PIPER_VOICE=en_US-arctic-medium, PIPER_BOOTSTRAP=1

# Mumble Voice Server (PTT voice input to AI agent)
# MUMBLE_SUPERUSER_PASSWORD=changeme-mumble-admin
# MUMBLE_SERVER_PASSWORD=changeme-mumble-access
# MUMBLE_BOT_USERNAME=BastionBot
# MUMBLE_TTS_ENABLED=true

# Database Configuration (use defaults for development)
NEO4J_USER=neo4j
NEO4J_PASSWORD=plato_password
QDRANT_API_KEY=
DATA_WORKSPACE_PASSWORD=changeme

# SearXNG (optional)
SEARXNG_SECRET=changeme-searxng-secret

# Microsoft OAuth (optional - external connections / email)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=

# Application Configuration
UPLOAD_MAX_SIZE=100MB
PROCESSING_TIMEOUT=300
QUALITY_THRESHOLD=0.7
EMBEDDING_BATCH_SIZE=100

# Map (PMTiles basemap; optional legacy tileserver)
# PMTILES_DATA_PATH=./pmtiles-data
# VITE_PMTILES_URL=/pmtiles/world.pmtiles
# Legacy: VITE_MAP_TILE_URL=http://localhost:8080

# Routing (Valhalla default; set ROUTING_PROVIDER=osrm and OSRM_BASE_URL for legacy OSRM)
# VALHALLA_DATA_PATH=./valhalla-data
# VALHALLA_BASE_URL=http://valhalla:8002
# ROUTING_PROVIDER=valhalla

# Development Settings
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3050

# LLM Orchestrator: set to true to disable Editor Engine routing so editor-doc requests
# go to chat or default Agent Factory profile (for testing Agent Factory on fiction/outline etc.).
# DISABLE_EDITOR_ENGINE_ROUTING=false

# Security (change in production)
SECRET_KEY=your-secret-key-change-in-production
