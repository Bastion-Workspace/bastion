## The Contract

Every tool has three typed components:

### 1. Inputs (required parameters)
Data the tool MUST receive to execute. Wireable in the Workflow Composer.

### 2. Params (optional configuration)
Static config with defaults. Set at design time, not wired from data flow.

### 3. Outputs (typed return fields)
Named, typed fields the tool produces. MUST include `formatted: text`. Downstream steps reference by name.

---

## Implementation Pattern

### Complete Example

```python
from pydantic import BaseModel, Field
from typing import List, Optional
from orchestrator.utils.action_io_registry import register_action


# ── I/O Models ───────────────────────────────────────────

class SearchDocumentsInputs(BaseModel):
    """Required inputs — wireable from upstream steps."""
    query: text = Field(description="Search query (natural language or keywords)")

class SearchDocumentsParams(BaseModel):
    """Optional configuration — set at design time."""
    limit: int = Field(default=5, description="Max results to return")
    scope: text = Field(default="all", description="my_docs, team_docs, global_docs, or all")
    file_types: Optional[List[text]] = Field(default=None, description="Filter by extension")

class DocumentRef(BaseModel):
    """A reference to a found document. Reusable across tools."""
    document_id: text
    title: text
    filename: text
    file_type: text
    folder_path: text
    relevance_score: number
    content_preview: text

class SearchDocumentsOutputs(BaseModel):
    """Typed outputs — every field is individually addressable."""
    documents: List[DocumentRef] = Field(description="Matching documents")
    count: number = Field(description="Number of results found")
    query_used: text = Field(description="The query that was executed")
    formatted: text = Field(description="Human-readable summary for LLM/chat")


# ── Tool Function (unified return) ──────────────────────

async def search_documents_tool(
    query: str,
    limit: int = 5,
    scope: str = "all",
    file_types: list = None,
    user_id: str = "system"
) -> dict:
    """
    Search documents in the knowledge base.
    Returns structured dict matching SearchDocumentsOutputs.
    """
    client = await get_backend_tool_client()
    result = await client.search_documents(query=query, user_id=user_id, limit=limit)

    documents = [
        {
            "document_id": doc["document_id"],
            "title": doc["title"],
            "filename": doc["filename"],
            "file_type": doc.get("file_type", "md"),
            "folder_path": doc.get("folder_path", ""),
            "relevance_score": doc.get("relevance_score", 0),
            "content_preview": doc.get("content_preview", "")[:200]
        }
        for doc in result.get("results", [])
    ]

    # Build formatted string (what the LLM and chat see)
    formatted_parts = [f"Found {len(documents)} document(s):"]
    for i, doc in enumerate(documents, 1):
        formatted_parts.append(f"\n{i}. **{doc['title']}** (ID: {doc['document_id']})")
        if doc["content_preview"]:
            formatted_parts.append(f"   Preview: {doc['content_preview']}...")

    return {
        "documents": documents,
        "count": len(documents),
        "query_used": query,
        "formatted": "\n".join(formatted_parts)
    }


# ── Registry Entry ───────────────────────────────────────

register_action(
    name="search_documents",
    category="search",
    description="Search documents in the knowledge base by query",
    inputs_model=SearchDocumentsInputs,
    params_model=SearchDocumentsParams,
    outputs_model=SearchDocumentsOutputs,
    tool_function=search_documents_tool
)
```

### Shared Type Models

Common types should be defined ONCE and reused across tools:

```python
# orchestrator/utils/tool_type_models.py

from pydantic import BaseModel, Field
from typing import Optional

class DocumentRef(BaseModel):
    """Standard document reference — reused by all file/document tools."""
    document_id: str
    title: str
    filename: str
    file_type: str
    folder_path: str
    scope: str = "my_docs"
    modified_at: Optional[str] = None

class TodoItem(BaseModel):
    """Standard todo/task reference — reused by all task tools."""
    todo_id: str
    title: str
    state: str
    priority: Optional[str] = None
    deadline: Optional[str] = None
    tags: list = []
    file_path: str

class NotificationResult(BaseModel):
    """Standard notification result."""
    success: bool
    message_id: Optional[str] = None
    channel: Optional[str] = None
```

