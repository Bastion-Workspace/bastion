## Anti-patterns

```python
# ❌ WRONG: Returns only a string (no typed fields for wiring)
async def my_tool(query: str) -> str:
    return f"Found {count} items"

# ❌ WRONG: Returns dict but no 'formatted' field (breaks LLM consumption)
async def my_tool(query: str) -> dict:
    return {"results": [...], "count": 5}
    # LLM gets: "{'results': [...], 'count': 5}" — ugly, unreadable

# ❌ WRONG: Creating a _structured variant alongside _tool
async def my_tool(query: str) -> str: ...           # Old
async def my_structured(query: str) -> dict: ...    # Variant
# Now there are two functions to maintain forever

# ❌ WRONG: Output fields not individually addressable
class MyOutputs(BaseModel):
    data: dict      # Opaque blob
    formatted: str

# ❌ WRONG: Overly strict types that prevent valid chains
class MyInputs(BaseModel):
    document_id: DocumentRef   # Forces upstream to produce exact model
    # Should be: document_id: str (text) — accepts any text, including a doc ID

# ✅ CORRECT: Unified return, typed fields, formatted included
class MyOutputs(BaseModel):
    results: List[ResultItem]
    count: int
    has_more: bool
    query_used: str
    formatted: str = Field(description="Human-readable summary")

async def my_tool(query: str) -> dict:
    results = do_search(query)
    return {
        "results": results,
        "count": len(results),
        "has_more": len(results) >= limit,
        "query_used": query,
        "formatted": f"Found {len(results)} items:\n" + format_results(results)
    }

register_action(
    name="my_tool", category="search", description="...",
    inputs_model=MyInputs, outputs_model=MyOutputs, tool_function=my_tool
)
```

